{
  "name": "jbac-tinygnn",
  "version": "0.1.4",
  "description": "Zero-dependency C++17 GNN inference engine with fused AVX2+OpenMP kernels for GCN, GraphSAGE, and GAT.",
  "homepage": "https://github.com/AnubhavChoudhery/TinyGNN",
  "license": "MIT",
  "supports": "!uwp & !arm & !arm64",
  "dependencies": [
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    }
  ],
  "features": {
    "openmp": {
      "description": "Enable OpenMP parallelization"
    }
  }
}
