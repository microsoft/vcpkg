{
  "name": "arpack-ng",
  "version": "3.9.1",
  "port-version": 2,
  "description": "ARPACK-NG is a collection of Fortran77 subroutines designed to solve large scale eigenvalue problems.",
  "homepage": "https://github.com/opencollab/arpack-ng",
  "license": "BSD-3-Clause",
  "supports": "!uwp",
  "dependencies": [
    {
      "name": "blas",
      "default-features": false,
      "features": [
        "force-reference-blas"
      ],
      "platform": "windows & static & !mingw"
    },
    {
      "name": "blas",
      "platform": "!(windows & static & !mingw)"
    },
    {
      "name": "lapack",
      "default-features": false,
      "features": [
        "force-reference-lapack"
      ],
      "platform": "windows & static & !mingw"
    },
    {
      "name": "lapack",
      "platform": "!(windows & static & !mingw)"
    },
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    },
    {
      "name": "vcpkg-gfortran",
      "platform": "windows"
    }
  ]
}
