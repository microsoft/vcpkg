{
  "name": "hical61-hical",
  "version": "2.6.1",
  "description": "Modern C++20/C++26 high-performance web framework based on Boost.Asio with native HTTP/WebSocket stack",
  "homepage": "https://github.com/Hical61/Hical",
  "license": "MIT",
  "supports": "!uwp & !xbox & !android & !emscripten",
  "dependencies": [
    "boost-asio",
    "boost-json",
    "boost-system",
    {
      "name": "liburing",
      "platform": "linux"
    },
    "openssl",
    "picohttpparser",
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    },
    "zlib"
  ],
  "features": {
    "database": {
      "description": "Database middleware with MySQL support (requires Boost.MySQL)",
      "dependencies": [
        "boost-charconv",
        "boost-mysql"
      ]
    }
  }
}
