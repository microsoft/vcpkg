+++ b/zimpl-config.cmake.in
@@ -1,3 +1,8 @@
+if(WIN32)
+  include(CMakeFindDependencyMacro)
+  find_dependency(pcre2)
+endif()
+
 if(NOT TARGET libzimpl)
   include("${CMAKE_CURRENT_LIST_DIR}/zimpl-targets.cmake")
 endif()
