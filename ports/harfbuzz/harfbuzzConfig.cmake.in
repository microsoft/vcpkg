# For old projects where the minimum CMake version is lower than 3.3.
cmake_policy(SET CMP0012 NEW)
cmake_policy(SET CMP0054 NEW)
cmake_policy(SET CMP0057 NEW)

include(CMakeFindDependencyMacro)

# Traditional find module variables (vcpkg polyfill)
set(HARFBUZZ_INCLUDE_DIR "${VCPKG_INSTALLED_DIR}/${VCPKG_TARGET_TRIPLET}/include/harfbuzz" CACHE INTERNAL "")
set(HARFBUZZ_INCLUDE_DIRS "${HARFBUZZ_INCLUDE_DIR}")
set(HARFBUZZ_LIBRARY harfbuzz::harfbuzz CACHE INTERNAL "")
set(HARFBUZZ_LIBRARIES harfbuzz::harfbuzz)

if(TARGET harfbuzz)
    set(HARFBUZZ_FOUND TRUE)
    return()
endif()

set(HARFBUZZ_FEATURES @FEATURES@)

unset(__quiet)
if(${CMAKE_FIND_PACKAGE_NAME}_FIND_QUIETLY)
    set(__quiet QUIET)
endif()

find_dependency(PkgConfig)
pkg_check_modules(harfbuzz ${__quiet} IMPORTED_TARGET harfbuzz)
if(TARGET PkgConfig::harfbuzz)
    add_library(harfbuzz ALIAS PkgConfig::harfbuzz)
    add_library(harfbuzz::harfbuzz ALIAS PkgConfig::harfbuzz)
endif()

pkg_check_modules(harfbuzz-gpu ${__quiet} IMPORTED_TARGET harfbuzz-gpu)
if(TARGET PkgConfig::harfbuzz-gpu)
    add_library(harfbuzz::harfbuzz-gpu ALIAS PkgConfig::harfbuzz-gpu)
endif()

pkg_check_modules(harfbuzz-raster ${__quiet} IMPORTED_TARGET harfbuzz-raster)
if(TARGET PkgConfig::harfbuzz-raster)
    add_library(harfbuzz::harfbuzz-raster ALIAS PkgConfig::harfbuzz-raster)
endif()

pkg_check_modules(harfbuzz-subset ${__quiet} IMPORTED_TARGET harfbuzz-subset)
if(TARGET PkgConfig::harfbuzz-subset)
    add_library(harfbuzz::harfbuzz-subset ALIAS PkgConfig::harfbuzz-subset)
endif()

pkg_check_modules(harfbuzz-vector ${__quiet} IMPORTED_TARGET harfbuzz-vector)
if(TARGET PkgConfig::harfbuzz-vector)
    add_library(harfbuzz::harfbuzz-vector ALIAS PkgConfig::harfbuzz-vector)
endif()

if ("cairo" IN_LIST HARFBUZZ_FEATURES)
    pkg_check_modules(harfbuzz-cairo ${__quiet} IMPORTED_TARGET harfbuzz-cairo)
    if(TARGET PkgConfig::harfbuzz-cairo)
        add_library(harfbuzz::harfbuzz-cairo ALIAS PkgConfig::harfbuzz-cairo)
    endif()
endif()

if ("icu" IN_LIST HARFBUZZ_FEATURES)
    pkg_check_modules(harfbuzz-icu ${__quiet} IMPORTED_TARGET harfbuzz-icu)
    if(TARGET PkgConfig::harfbuzz-icu)
        add_library(harfbuzz::harfbuzz-icu ALIAS PkgConfig::harfbuzz-icu)
    endif()
endif()

if ("introspection" IN_LIST HARFBUZZ_FEATURES)
    pkg_check_modules(harfbuzz-gobject ${__quiet} IMPORTED_TARGET harfbuzz-gobject)
    if(TARGET PkgConfig::harfbuzz-gobject)
        add_library(harfbuzz::harfbuzz-gobject ALIAS PkgConfig::harfbuzz-gobject)
    endif()
endif()
