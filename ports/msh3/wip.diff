--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -40,20 +40,15 @@ if (WIN32)
 set(CMAKE_INSTALL_RPATH_USE_LINK_PATH TRUE)
 
 if (WIN32)
