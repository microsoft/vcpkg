Subject: [PATCH 09/22] expat

---
 CMake/FindEXPAT.cmake | 11 ++++++-----
 1 file changed, 6 insertions(+), 5 deletions(-)

diff --git a/CMake/FindEXPAT.cmake b/CMake/FindEXPAT.cmake
index 545d9cc2..85ca2353 100644
--- a/CMake/FindEXPAT.cmake
+++ b/CMake/FindEXPAT.cmake
@@ -88,6 +88,7 @@ if (POLICY CMP0159)
   cmake_policy(SET CMP0159 NEW) # file(STRINGS) with REGEX updates CMAKE_MATCH_<n>
 endif ()
 
+if(0)
 find_package(PkgConfig QUIET)
 if(PkgConfig_FOUND)
   pkg_check_modules(PC_EXPAT QUIET expat)
@@ -183,16 +184,16 @@ include(FindPackageHandleStandardArgs)
 find_package_handle_standard_args(EXPAT
                                   REQUIRED_VARS EXPAT_LIBRARY EXPAT_INCLUDE_DIR
                                   VERSION_VAR EXPAT_VERSION)
+endif(0)
+find_package(EXPAT NAMES expat)
 
 # Copy the results to the output variables and target.
 if(EXPAT_FOUND)
-  set(EXPAT_INCLUDE_DIRS ${EXPAT_INCLUDE_DIR})
-
-  if(NOT EXPAT_LIBRARIES)
-    set(EXPAT_LIBRARIES ${EXPAT_LIBRARY})
-  endif()
 
   if(NOT TARGET EXPAT::EXPAT)
+    add_library(EXPAT::EXPAT INTERFACE IMPORTED)
+    target_link_libraries(EXPAT::EXPAT INTERFACE expat::expat)
+  elseif(0)
     include(vtkDetectLibraryType)
     set(expat_location)
     if(EXPAT_LIBRARY_RELEASE)
