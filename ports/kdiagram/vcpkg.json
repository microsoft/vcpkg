{
  "name": "kdiagram",
  "version": "3.0.1",
  "description": "Powerful libraries (KChart, KGantt) for creating business diagrams",
  "homepage": "https://invent.kde.org/graphics/kdiagram",
  "license": "GPL-2.0-or-later",
  "dependencies": [
    "ecm",
    {
      "name": "qtbase",
      "default-features": false
    },
    "qtsvg",
    {
      "name": "qttools",
      "host": true,
      "default-features": false,
      "features": [
        "linguist"
      ]
    },
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    }
  ]
}
