{
  "name": "cnats",
  "version": "3.12.0",
  "port-version": 1,
  "description": "A C client for the NATS messaging system",
  "homepage": "https://github.com/nats-io/nats.c",
  "license": "Apache-2.0",
  "dependencies": [
    "openssl",
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    }
  ],
  "features": {
    "sodium": {
      "description": "Use libsodium for improved NKey signing performance",
      "supports": "!windows",
      "dependencies": [
        "libsodium"
      ]
    },
    "streaming": {
      "description": "Include deprecated NATS Streaming (STAN) APIs in the NATS library",
      "supports": "!windows",
      "dependencies": [
        "protobuf-c"
      ]
    }
  }
}
