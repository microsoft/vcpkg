diff --git a/cmake/huira-packaging.cmake b/cmake/huira-packaging.cmake
index 674050c..88d58b5 100644
--- a/cmake/huira-packaging.cmake
+++ b/cmake/huira-packaging.cmake
@@ -46,5 +46,4 @@ install(FILES
         "${CMAKE_BINARY_DIR}/huiraConfig.cmake"
         "${CMAKE_BINARY_DIR}/huiraConfigVersion.cmake"
         "${CMAKE_SOURCE_DIR}/cmake/find/FindCSPICE.cmake"
-        "${CMAKE_SOURCE_DIR}/cmake/find/FindCFITSIO.cmake"
         DESTINATION ${CMAKE_INSTALL_LIBDIR}/cmake/huira)
diff --git a/cmake/huira-setup.cmake b/cmake/huira-setup.cmake
index a348c7d..f2f6a65 100644
--- a/cmake/huira-setup.cmake
+++ b/cmake/huira-setup.cmake
@@ -23,8 +23,9 @@ target_compile_definitions(huira INTERFACE
 # Find dependencies (in order):
 find_package(assimp CONFIG REQUIRED)
 
-find_package(CFITSIO REQUIRED)
-if(WIN32 AND TARGET CFITSIO::CFITSIO)
+find_package(CFITSIO NAMES cfitsio REQUIRED)
+add_library(CFITSIO::CFITSIO ALIAS CFITSIO::cfitsio)
+if(0)
     # Conda-forge's cfitsio includes 'm' in its link interface, which doesn't
     # exist on Windows (math functions are in the CRT). Remove it.
     get_target_property(_cfitsio_libs CFITSIO::CFITSIO INTERFACE_LINK_LIBRARIES)
diff --git a/cmake/huiraConfig.cmake.in b/cmake/huiraConfig.cmake.in
index 4aad10a..7be4b6f 100644
--- a/cmake/huiraConfig.cmake.in
+++ b/cmake/huiraConfig.cmake.in
@@ -8,8 +8,8 @@ list(APPEND CMAKE_MODULE_PATH "${CMAKE_CURRENT_LIST_DIR}")
 # Find dependencies (in order):
 find_dependency(assimp CONFIG)
 
-find_dependency(CFITSIO)
-if(WIN32 AND TARGET CFITSIO::CFITSIO)
+find_dependency(cfitsio CONFIG)
+if(0)
     get_target_property(_cfitsio_libs CFITSIO::CFITSIO INTERFACE_LINK_LIBRARIES)
     if(_cfitsio_libs)
         list(REMOVE_ITEM _cfitsio_libs "m")
