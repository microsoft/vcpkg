{
  "name": "wayland-protocols",
  "version": "1.49",
  "port-version": 1,
  "description": "wayland-protocols contains Wayland protocols that add functionality not available in the Wayland core protocol.",
  "homepage": "https://wayland.freedesktop.org",
  "license": "MIT",
  "dependencies": [
    {
      "name": "vcpkg-tool-meson",
      "host": true
    }
  ],
  "features": {
    "force-build": {
      "description": [
        "Generate protocol helper headers.",
        "Use the wayland-scanner host tool from vcpkg."
      ],
      "dependencies": [
        {
          "name": "wayland",
          "host": true,
          "features": [
            "scanner"
          ]
        },
        {
          "name": "wayland-protocols",
          "features": [
            "generated-headers"
          ]
        }
      ]
    },
    "generated-headers": {
      "description": [
        "Generate protocol helper headers.",
        "Requires the wayland-scanner host tool."
      ],
      "dependencies": [
        {
          "name": "wayland",
          "host": true,
          "features": [
            "scanner"
          ],
          "platform": "!windows & !osx & !android"
        }
      ]
    }
  }
}
