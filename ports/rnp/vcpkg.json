{
  "name": "rnp",
  "version": "0.18.1",
  "description": "Freely-licensed OpenPGP library and command-line tools",
  "homepage": "https://www.rnpgp.org",
  "license": "BSD-2-Clause",
  "dependencies": [
    "botan",
    "bzip2",
    {
      "name": "dirent",
      "platform": "windows & static"
    },
    {
      "name": "getopt-win32",
      "platform": "windows & static"
    },
    "json-c",
    {
      "name": "pkgconf",
      "host": true
    },
    "sexpp",
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    },
    "zlib"
  ],
  "features": {
    "openssl": {
      "description": "Use OpenSSL instead of Botan as the crypto backend",
      "supports": "!android & !(linux & arm64)",
      "dependencies": [
        "openssl"
      ]
    },
    "tools": {
      "description": "Build the rnp and rnpkeys command line tools"
    }
  }
}
