{
  "name": "mygui",
  "version": "3.4.4",
  "description": "Fast, flexible and simple GUI",
  "homepage": "http://mygui.info",
  "license": "MIT",
  "supports": "!uwp",
  "dependencies": [
    "freetype",
    "sdl2-image",
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    }
  ],
  "features": {
    "obsolete": {
      "description": "Keep obsolete functions."
    },
    "plugins": {
      "description": "Build MyGUI plugins."
    },
    "msdf": {
      "description": "Enable msdf support"
    },
    "tools": {
      "description": "Install MyGUI tools.",
      "supports": "!android & !osx"
    }
  }
}
