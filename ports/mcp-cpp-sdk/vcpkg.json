{
  "name": "mcp-cpp-sdk",
  "version": "0.1.0",
  "port-version": 0,
  "description": "Model Context Protocol SDK for C++ - Build production-ready MCP servers and clients with complete protocol support including Streamable HTTP transport and OAuth-based authorization",
  "homepage": "https://github.com/itcv-GmbH/cpp-mcp-sdk",
  "license": "MIT",
  "supports": "!uwp",
  "dependencies": [
    "boost-asio",
    "boost-beast",
    "boost-filesystem",
    "boost-process",
    "boost-system",
    "jsoncons",
    "openssl",
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    }
  ],
  "features": {
    "examples": {
      "description": "Build example applications"
    },
    "tests": {
      "description": "Build tests (enables Catch2 test targets)",
      "dependencies": [
        "catch2"
      ]
    }
  }
}
