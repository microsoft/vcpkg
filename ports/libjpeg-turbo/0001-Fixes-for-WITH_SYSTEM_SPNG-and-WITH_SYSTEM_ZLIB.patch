From 64831068d6260f1c631c0f0166e6d19899be1fa5 Mon Sep 17 00:00:00 2001
From: tartanpaint <35690467+tartanpaint@users.noreply.github.com>
Date: Tue, 14 Jul 2026 10:07:55 +0100
Subject: [PATCH] Fixes for WITH_SYSTEM_SPNG and WITH_SYSTEM_ZLIB

---
 CMakeLists.txt          | 22 ++++++++++++++++++----
 release/Config.cmake.in | 11 +++++++++++
 2 files changed, 29 insertions(+), 4 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index f1442728..7d8f9e7a 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -735,10 +735,24 @@ if(WITH_TURBOJPEG OR WITH_TOOLS OR WITH_TESTS)
   boolean_number(WITH_SYSTEM_SPNG)
   report_option(WITH_SYSTEM_SPNG "System-supplied libspng")
   if(WITH_SYSTEM_SPNG)
-    include(FindPkgConfig)
-    pkg_check_modules(spng REQUIRED spng IMPORTED_TARGET)
-    unset(SPNG_STATIC_SOURCES)
-    set(SPNG_LIBRARY PkgConfig::spng)
+    find_package(SPNG CONFIG QUIET)
+    if(SPNG_FOUND)
+        unset(SPNG_STATIC_SOURCES)
+        if(TARGET spng::spng)
+            set(SPNG_LIBRARY spng::spng)
+        elseif(TARGET spng::spng_shared)
+            set(SPNG_LIBRARY spng::spng_shared)
+        elseif(TARGET spng::spng_static)
+            set(SPNG_LIBRARY spng::spng_static)
+        else()
+            message(FATAL_ERROR "SPNG_FOUND is true, but no recognized targets were found.")
+        endif()
+    else()
+        include(FindPkgConfig)
+        pkg_search_module(spng REQUIRED IMPORTED_TARGET libspng_static spng_static libspng spng)
+        unset(SPNG_STATIC_SOURCES)
+        set(SPNG_LIBRARY PkgConfig::spng)
+    endif()
   else()
     option(WITH_SYSTEM_ZLIB
       "Build ${CMAKE_PROJECT_NAME} against the system-supplied zlib implementation rather than the implementation in the ${CMAKE_PROJECT_NAME} source tree"
diff --git a/release/Config.cmake.in b/release/Config.cmake.in
index 0c1ba8aa..639cb477 100644
--- a/release/Config.cmake.in
+++ b/release/Config.cmake.in
@@ -1,4 +1,15 @@
 @PACKAGE_INIT@
 
+include(CMakeFindDependencyMacro)
+
+# If we built with system SPNG/ZLIB, the downstream consumers need them too
+if(@WITH_SYSTEM_SPNG@)
+    find_dependency(SPNG)
+endif()
+
+if(@WITH_SYSTEM_ZLIB@ OR @WITH_SYSTEM_SPNG@)
+    find_dependency(ZLIB)
+endif()
+
 include("${CMAKE_CURRENT_LIST_DIR}/@CMAKE_PROJECT_NAME@Targets.cmake")
 check_required_components("@CMAKE_PROJECT_NAME@")
-- 
2.47.1.windows.1

