Use vcpkg-provided asmjit and cpuinfo instead of submodule fetch, and propagate
them through fbgemm's PUBLIC link interface so the installed fbgemmLibraryConfig
records them for downstream consumers.

--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -126,6 +126,19 @@
 # Setup OpenMP Flags
 ################################################################################

+# vcpkg: use the system asmjit/cpuinfo ports. Aliasing the system targets to the
+# bare names that the fbgemm CMakeLists `if(NOT TARGET asmjit)` checks bypasses
+# the submodule-fetch blocks at the bottom of this file. cpp_library DEPS pass
+# the bare names, which resolve through the aliases.
+find_package(asmjit CONFIG REQUIRED)
+find_package(cpuinfo CONFIG REQUIRED)
+if(NOT TARGET asmjit)
+  add_library(asmjit ALIAS asmjit::asmjit)
+endif()
+if(NOT TARGET cpuinfo)
+  add_library(cpuinfo ALIAS cpuinfo::cpuinfo)
+endif()
+
 find_package(OpenMP)

 if(OpenMP_FOUND)
@@ -430,6 +443,8 @@
   DEPS
     fbgemm_generic
     ${fbgemm_targets}
+    asmjit::asmjit
+    cpuinfo::cpuinfo
 )

 get_filelist("get_fbgemm_public_headers()" FBGEMM_PUBLIC_HEADERS)
