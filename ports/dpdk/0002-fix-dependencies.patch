     dpdk_conf.set10('RTE_EAL_NUMA_AWARE_HUGEPAGES', true)
 endif
diff --git a/lib/vhost/meson.build b/lib/vhost/meson.build
index 6a24981..5283e79 100644
--- a/lib/vhost/meson.build
+++ b/lib/vhost/meson.build
