{
  "name": "dpdk",
  "version": "26.3",
  "port-version": 4,
  "description": "A set of libraries and drivers for fast packet processing",
  "homepage": "https://www.dpdk.org/",
  "documentation": "https://doc.dpdk.org/guides/",
  "license": "BSD-3-Clause",
  "supports": "freebsd | linux | (windows & x64)",
  "dependencies": [
    {
      "name": "libarchive",
      "default-features": false
    },
    {
      "name": "numactl",
      "platform": "linux"
    },
    {
      "name": "vcpkg-get-python-packages",
      "host": true
    },
    {
      "name": "vcpkg-tool-meson",
      "host": true
    }
  ],
  "features": {
    "docs": {
      "description": "Build and install docs"
    },
    "mlx5": {
      "description": "Build NVIDIA MLX5 drivers",
      "supports": "linux",
      "dependencies": [
        "rdma-core"
      ]
    },
    "pmd-bnx2x": {
      "description": "Build BNX2X Poll Mode Driver",
      "supports": "!windows",
      "dependencies": [
        "zlib"
      ]
    },
    "pmd-compress-isal": {
      "description": "Build ISA-L Compression Poll Mode Driver",
      "supports": "!uwp & (x64 | (arm64 & linux))",
      "dependencies": [
        "isal"
      ]
    },
    "pmd-compress-zlib": {
      "description": "Build ZLIB Compression Poll Mode Driver",
      "dependencies": [
        "zlib"
      ]
    },
    "pmd-crypto-ccp": {
      "description": "Build AMD CCP Crypto Poll Mode Driver",
      "supports": "linux",
      "dependencies": [
        "openssl"
      ]
    },
    "pmd-crypto-openssl": {
      "description": "Build OpenSSL Crypto Poll Mode Driver",
      "supports": "!windows",
      "dependencies": [
        "openssl"
      ]
    },
    "pmd-ipn3ke": {
      "description": "Build IPN3KE Poll Mode Driver",
      "supports": "!windows",
      "dependencies": [
        "dtc"
      ]
    },
    "pmd-mana": {
      "description": "Build MANA Poll Mode Driver",
      "supports": "linux",
      "dependencies": [
        "rdma-core"
      ]
    },
    "pmd-mlx4": {
      "description": "Build NVIDIA MLX4 Poll Mode Driver",
      "supports": "linux",
      "dependencies": [
        "rdma-core"
      ]
    },
    "pmd-pcap": {
      "description": "Build PCAP Poll Mode Driver",
      "supports": "!windows",
      "dependencies": [
        "libpcap"
      ]
    },
    "qat": {
      "description": "Build Intel QuickAssist drivers",
      "supports": "!windows",
      "dependencies": [
        "openssl"
      ]
    },
    "rawdev-ifpga": {
      "description": "Build IFPGA Rawdev Driver",
      "supports": "!windows",
      "dependencies": [
        "dtc"
      ]
    },
    "tests": {
      "description": "Build and install tests"
    },
    "trace": {
      "description": "Build with fast path traces enabled"
    }
  }
}
