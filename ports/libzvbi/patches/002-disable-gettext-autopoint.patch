+    AC_CHECK_LIB([iconv], [libiconv], [am_cv_func_iconv=yes; LIBICONV="-liconv"])
+  ])
+])
+AC_SUBST([LIBICONV])
 if test "x$am_cv_func_iconv" != xyes; then
   AC_MSG_ERROR([iconv() not found])
 fi
