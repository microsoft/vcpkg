diff --git a/contrib/sys/time.h b/contrib/sys/time.h
new file mode 100644
index 0000000..8361373
--- /dev/null
+++ b/contrib/sys/time.h
@@ -0,0 +1,26 @@
+/* sys/time.h - MSVC compatibility shim for zvbi internal sources
+ * Provides struct timeval (from winsock2) and gettimeofday().
+ */
+#ifndef _ZVBI_COMPAT_SYS_TIME_H
+#define _ZVBI_COMPAT_SYS_TIME_H
+
+#include <winsock2.h>
+#include <windows.h>
+
+static __inline int zvbi_gettimeofday_(struct timeval *tv, void *tz)
+{
+    FILETIME ft;
+    unsigned __int64 t;
+    (void)tz;
+    if (!tv) return -1;
+    GetSystemTimeAsFileTime(&ft);
+    t = ((unsigned __int64)ft.dwHighDateTime << 32) | ft.dwLowDateTime;
+    /* Convert from 100-ns intervals since 1601 to microseconds since 1970 */
+    t -= 116444736000000000ULL;
+    tv->tv_sec  = (long)(t / 10000000ULL);
+    tv->tv_usec = (long)((t % 10000000ULL) / 10);
+    return 0;
+}
+#define gettimeofday zvbi_gettimeofday_
+
+#endif /* _ZVBI_COMPAT_SYS_TIME_H */
