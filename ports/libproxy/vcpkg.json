{
  "name": "libproxy",
  "version": "0.5.12",
  "description": "libproxy is a library that provides automatic proxy configuration management.",
  "homepage": "https://github.com/libproxy/libproxy",
  "license": "LGPL-2.1-only",
  "supports": "!(uwp | xbox | android)",
  "dependencies": [
    "glib",
    "pkgconf",
    {
      "name": "vcpkg-tool-meson",
      "host": true
    }
  ],
  "features": {
    "curl": {
      "description": "Build with cURL support",
      "dependencies": [
        "curl"
      ]
    },
    "duktape": {
      "description": "Build with PAC Runner Duktape support",
      "dependencies": [
        "duktape"
      ]
    },
    "introspection": {
      "description": "Build introspection support",
      "dependencies": [
        "gobject-introspection"
      ]
    },
    "tests": {
      "description": "Build tests"
    },
    "vala": {
      "description": "Build Vala vapi support",
      "dependencies": [
        {
          "name": "libproxy",
          "features": [
            "introspection"
          ]
        },
        "vala"
      ]
    }
  }
}
