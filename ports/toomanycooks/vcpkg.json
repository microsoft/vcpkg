{
  "name": "toomanycooks",
  "version": "1.5.0",
  "description": "The C++20 coroutine framework with no compromises. Excellent performance, simple syntax, and powerful features.",
  "homepage": "https://github.com/tzcnt/TooManyCooks",
  "documentation": "https://fleetcode.com/oss/tmc/docs",
  "license": "BSL-1.0",
  "supports": "!uwp & !android",
  "dependencies": [
    "boost-asio",
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    }
  ],
  "default-features": [
    "hwloc"
  ],
  "features": {
    "debug-task-alloc-count": {
      "description": "Enable TMC_DEBUG_TASK_ALLOC_COUNT. See documentation at https://fleetcode.com/oss/tmc/docs/v1.5/build_flags.html#tmc-debug-task-alloc-count"
    },
    "debug-thread-creation": {
      "description": "Enable TMC_DEBUG_THREAD_CREATION. See documentation at https://fleetcode.com/oss/tmc/docs/v1.5/build_flags.html#tmc-debug-thread-creation"
    },
    "funcoro": {
      "description": "Set TMC_WORK_ITEM=FUNCORO. See documentation at https://fleetcode.com/oss/tmc/docs/v1.5/build_flags.html#tmc-work-item"
    },
    "hwloc": {
      "description": "Enable hwloc topology-aware thread placement. See documentation at https://fleetcode.com/oss/tmc/docs/v1.5/build_flags.html#tmc-use-hwloc",
      "dependencies": [
        "hwloc"
      ]
    },
    "more-threads": {
      "description": "Enable TMC_MORE_THREADS. See documentation at https://fleetcode.com/oss/tmc/docs/v1.5/build_flags.html#tmc-more-threads"
    },
    "nodiscard-await": {
      "description": "Enable TMC_NODISCARD_AWAIT. See documentation at https://fleetcode.com/oss/tmc/docs/v1.5/build_flags.html#tmc-nodiscard-await"
    },
    "standalone-compilation": {
      "description": "Enable TMC_STANDALONE_COMPILATION. See documentation at https://fleetcode.com/oss/tmc/docs/v1.5/build_flags.html#build-modes"
    },
    "trivial-task": {
      "description": "Enable TMC_TRIVIAL_TASK. See documentation at https://fleetcode.com/oss/tmc/docs/v1.5/build_flags.html#tmc-trivial-task"
    },
    "windows-dll": {
      "description": "Enable TMC_WINDOWS_DLL and TMC_STANDALONE_COMPILATION. See documentation at https://fleetcode.com/oss/tmc/docs/v1.5/build_flags.html#build-modes",
      "supports": "windows"
    }
  }
}
