 1 file changed, 11 insertions(+), 7 deletions(-)

diff --git a/src/contrib/dragonbox.h b/src/contrib/dragonbox.h
index de5a79f11..6160e5fcd 100644
--- a/src/contrib/dragonbox.h
+++ b/src/contrib/dragonbox.h
@@ -920,16 +920,20 @@ namespace jkj {
 #endif
                 }
 
-                template <template <stdr::size_t> class Info, stdr::int_least32_t min_exponent,
