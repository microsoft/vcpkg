{
  "name": "faudio",
  "version-string": "25.08",
  "port-version": 1,
  "description": "FAudio - accuracy-focused XAudio reimplementation for open platforms",
  "homepage": "https://fna-xna.github.io/",
  "license": "Zlib",
  "supports": "!uwp",
  "dependencies": [
    {
      "name": "faudio",
      "default-features": false,
      "features": [
        "sdl3"
      ],
      "platform": "!windows"
    },
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    }
  ],
  "features": {
    "sdl3": {
      "description": "use the SDL3 audio backend",
      "dependencies": [
        "sdl3"
      ]
    }
  }
}
