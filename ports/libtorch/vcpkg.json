{
  "name": "libtorch",
  "version": "2.7.1",
  "description": "Tensors and Dynamic neural networks in Python with strong GPU acceleration",
  "homepage": "https://pytorch.org/",
  "license": null,
  "dependencies": [
    "blas",
    "cpp-httplib",
    "cpuinfo",
    "eigen3",
    "flatbuffers",
    {
      "name": "flatbuffers",
      "host": true
    },
    "fmt",
    "foxi",
    "fp16",
    "gemmlowp",
    "gflags",
    "glog",
    {
      "name": "kleidiai",
      "platform": "arm"
    },
    "lapack",
    "lmdb",
    "mimalloc",
    "onnx",
    "onnx-optimizer",
    "opencl",
    "opentelemetry-cpp",
    "pocketfft",
    "protobuf",
    {
      "name": "protobuf",
      "host": true
    },
    "pthreadpool",
    "sleef",
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    },
    {
      "name": "vcpkg-get-python-packages",
      "host": true
    },
    "xnnpack",
    {
      "name": "xnnpack",
      "features": [
        "kleidiai"
      ],
      "platform": "arm64"
    }
  ],
  "features": {
    "cuda": {
      "description": "Build with CUDA GPU backend",
      "supports": "!(windows & staticcrt)",
      "dependencies": [
        "cuda",
        "cudnn",
        "cudnn-frontend",
        {
          "name": "gloo",
          "features": [
            "cuda"
          ],
          "platform": "linux"
        },
        "magma",
        "nvidia-cutlass",
        {
          "name": "tensorpipe",
          "features": [
            "cuda"
          ],
          "platform": "linux"
        }
      ]
    },
    "dist": {
      "description": "Use distributed with MPI, Gloo, libuv, TensorPipe",
      "supports": "linux | windows | osx",
      "dependencies": [
        {
          "name": "gloo",
          "platform": "linux"
        },
        {
          "name": "libuv",
          "platform": "windows | osx"
        },
        {
          "name": "tensorpipe",
          "platform": "linux | osx"
        }
      ]
    },
    "llvm": {
      "description": "Build with LLVM",
      "dependencies": [
        "llvm"
      ]
    },
    "mpi": {
      "description": "Use MPI for Caffe2. Only available if USE_DISTRIBUTED is on",
      "dependencies": [
        {
          "name": "libtorch",
          "default-features": false,
          "features": [
            "dist"
          ],
          "platform": "linux"
        },
        "mpi"
      ]
    },
    "nnpack": {
      "description": "Build with NNPack",
      "supports": "linux | osx",
      "dependencies": [
        {
          "name": "kleidiai",
          "platform": "arm64"
        },
        "nnpack"
      ]
    },
    "openmp": {
      "description": "Use OpenMP for parallel code"
    },
    "vulkan": {
      "description": "Build with Vulkan GPU backend",
      "dependencies": [
        {
          "name": "shaderc",
          "host": true
        },
        "vulkan",
        "vulkan-loader",
        "vulkan-memory-allocator"
      ]
    }
  }
}
