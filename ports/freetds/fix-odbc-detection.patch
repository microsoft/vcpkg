diff --git a/CMakeLists.txt b/CMakeLists.txt
index a3c8fe3..5335ddb 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -88,6 +88,19 @@ endmacro()
 
 file(WRITE "${CMAKE_BINARY_DIR}/include/config.h.in" "/* Automatic generated by cmake */\n\n#define _freetds_config_h_\n")
 
+
+# Ensure vcpkg installed headers (e.g. unixodbc sql.h) are found during configure checks
+if(DEFINED VCPKG_INSTALLED_DIR AND DEFINED VCPKG_TARGET_TRIPLET)
+list(APPEND CMAKE_REQUIRED_INCLUDES "${VCPKG_INSTALLED_DIR}/${VCPKG_TARGET_TRIPLET}/include")
+# FreeTDS' ODBC subdir does not add ODBC include dirs to compile targets.
+# Add vcpkg include dir globally so actual build steps can resolve sql.h/sqlext.h.
+include_directories("${VCPKG_INSTALLED_DIR}/${VCPKG_TARGET_TRIPLET}/include")
+endif()
+if(DEFINED VCPKG_INSTALLED_DIR AND DEFINED VCPKG_TARGET_TRIPLET
+        AND NOT CMAKE_BUILD_TYPE MATCHES "^[Rr]el")
+list(APPEND CMAKE_REQUIRED_INCLUDES "${VCPKG_INSTALLED_DIR}/${VCPKG_TARGET_TRIPLET}/debug/include")
+include_directories("${VCPKG_INSTALLED_DIR}/${VCPKG_TARGET_TRIPLET}/debug/include")
+endif()
 foreach(fn
 	arpa/inet.h
 	com_err.h
@@ -346,5 +359,10 @@ if(WIN32)
 		set(lib_ODBCINST ${lib_ODBCINST} legacy_stdio_definitions)
 	endif(LEGACY_STDIO)
 else()
 	search_library(SQLGetPrivateProfileString HAVE_SQLGETPRIVATEPROFILESTRING lib_ODBCINST "odbcinst;iodbcinst")
+	# In vcpkg, unixodbc is declared as a dependency on non-Windows.
+	# If configure-time probing misses it, force the expected installer lib name.
+	if(DEFINED VCPKG_INSTALLED_DIR AND DEFINED VCPKG_TARGET_TRIPLET AND NOT lib_ODBCINST)
+		set(lib_ODBCINST odbcinst)
+	endif()
 endif()
