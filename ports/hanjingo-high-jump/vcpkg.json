{
  "name": "hanjingo-high-jump",
  "version": "1.0.10",
  "maintainers": [
    "hanjingo",
    "hehehunanchina@live.com"
  ],
  "description": "Modern C++ library framework implemented by C++17. High-jump(hj) is a comprehensive C++ library providing utilities for algorithms, compression, cryptography, databases, encoding, hardware, I/O, logging, math, networking, OS operations, synchronization, testing, time handling, types, and more.",
  "homepage": "https://github.com/hanjingo/high-jump",
  "license": "GPL-3.0-or-later",
  "supports": "!uwp",
  "dependencies": [
    "bext-sml",
    "boost-algorithm",
    "boost-any",
    "boost-asio",
    "boost-beast",
    "boost-circular-buffer",
    "boost-coroutine2",
    "boost-filesystem",
    "boost-leaf",
    "boost-multi-index",
    "boost-optional",
    "boost-property-tree",
    "boost-stacktrace",
    "boost-uuid",
    "boost-variant",
    "concurrentqueue",
    "fmt",
    "nlohmann-json",
    {
      "name": "vcpkg-cmake",
      "host": true
    }
  ],
  "features": {
    "asr": {
      "description": "Enable automatic speech recognition support",
      "dependencies": [
        "whisper-cpp"
      ]
    },
    "behavior-tree": {
      "description": "Enable behavior tree support",
      "dependencies": [
        "behaviortree-cpp"
      ]
    },
    "bench": {
      "description": "Enable benchmark support",
      "dependencies": [
        "benchmark"
      ]
    },
    "ck": {
      "description": "Enable clickhouse database support",
      "dependencies": [
        "clickhouse-cpp"
      ]
    },
    "crash": {
      "description": "Enable crash support",
      "dependencies": [
        "breakpad"
      ]
    },
    "crypto": {
      "description": "Enable cryption/decryption support",
      "dependencies": [
        "openssl"
      ]
    },
    "cuda": {
      "description": "Enable CUDA support for GGML, Whisper",
      "dependencies": [
        {
          "name": "ggml",
          "features": [
            "cuda"
          ]
        },
        {
          "name": "whisper-cpp",
          "features": [
            "cuda"
          ]
        }
      ]
    },
    "fix": {
      "description": "Enable fix protocol support",
      "dependencies": [
        "hffix"
      ]
    },
    "flatbuffer": {
      "description": "Enable flatbuffer support",
      "dependencies": [
        "flatbuffers"
      ]
    },
    "gpu": {
      "description": "Enable GPU support",
      "dependencies": [
        "opencl"
      ]
    },
    "grpc": {
      "description": "Enable grpc support",
      "dependencies": [
        "grpc"
      ]
    },
    "gzip": {
      "description": "Enable gzip compression support",
      "dependencies": [
        "zlib",
        "zstd"
      ]
    },
    "http": {
      "description": "Enable HTTP support",
      "dependencies": [
        "cpp-httplib"
      ]
    },
    "lic": {
      "description": "Enable license support",
      "dependencies": [
        "jwt-cpp",
        "quirc"
      ]
    },
    "llama": {
      "description": "Enable llama support",
      "dependencies": [
        "llama-cpp"
      ]
    },
    "log": {
      "description": "Enable log support",
      "dependencies": [
        "spdlog"
      ]
    },
    "math": {
      "description": "Enable math support",
      "dependencies": [
        "boost-math",
        "eigen3"
      ]
    },
    "options": {
      "description": "Enable program options parse support",
      "dependencies": [
        "boost-program-options"
      ]
    },
    "pdf": {
      "description": "Enable PDF support",
      "dependencies": [
        "libharu"
      ]
    },
    "protobuf": {
      "description": "Enable protobuf support",
      "dependencies": [
        "protobuf"
      ]
    },
    "qrcode": {
      "description": "Enable QR code support",
      "dependencies": [
        "libqrencode",
        "quirc"
      ]
    },
    "redis": {
      "description": "Enable Redis support",
      "dependencies": [
        "hiredis"
      ]
    },
    "singleton": {
      "description": "Enable singleton support",
      "dependencies": [
        "boost-serialization"
      ]
    },
    "sqlite": {
      "description": "Enable SQLite support",
      "dependencies": [
        "sqlite3"
      ]
    },
    "sync": {
      "description": "Enable sync support",
      "dependencies": [
        "boost-interprocess",
        "boost-process",
        "boost-thread",
        "tbb"
      ]
    },
    "telemetry": {
      "description": "Enable telemetry support",
      "dependencies": [
        {
          "name": "opentelemetry-cpp",
          "default-features": false,
          "features": [
            "otlp-file",
            "otlp-http"
          ]
        }
      ]
    },
    "test": {
      "description": "Enable unit test support",
      "dependencies": [
        "gtest"
      ]
    },
    "timer": {
      "description": "Enable timer support",
      "dependencies": [
        "boost-timer"
      ]
    },
    "usb-bt": {
      "description": "Enable USB and Bluetooth support",
      "dependencies": [
        "hidapi"
      ]
    },
    "vector-index": {
      "description": "Enable vector database support",
      "dependencies": [
        "faiss"
      ]
    },
    "xml": {
      "description": "Enable XML support",
      "dependencies": [
        "pugixml"
      ]
    },
    "yaml": {
      "description": "Enable YAML support",
      "dependencies": [
        "yaml-cpp"
      ]
    },
    "zmq": {
      "description": "Enable ZeroMQ support",
      "dependencies": [
        "zeromq"
      ]
    }
  }
}
