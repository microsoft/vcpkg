diff --git a/cmake/FindFFmpeg.cmake b/cmake/FindFFmpeg.cmake
index 93d43c4a..06dfc0e8 100644
--- a/cmake/FindFFmpeg.cmake
+++ b/cmake/FindFFmpeg.cmake
@@ -4,6 +4,7 @@
 #  FFmpeg_FOUND         - System has all required components
 #  FFmpeg_INCLUDE_DIRS  - Include directories
 #  FFmpeg_LIBRARIES     - Libraries to link
+#  FFmpeg_LIBRARY_DIRS  - Library search directories
 #  HAVE_FFMPEG          - Set if found (for config header)
 #
 # Per-component variables:
@@ -11,6 +12,7 @@
 #  FFmpeg_<COMPONENT>_INCLUDE_DIRS
 #  FFmpeg_<COMPONENT>_LIBRARIES
 #  FFmpeg_<COMPONENT>_VERSION
+#  FFmpeg_<COMPONENT>_LIBRARY_DIRS
 
 if (NOT FFmpeg_FIND_COMPONENTS)
   set(FFmpeg_FIND_COMPONENTS AVCODEC AVFORMAT AVUTIL SWSCALE SWRESAMPLE)
@@ -24,6 +26,7 @@ find_package(PkgConfig QUIET)
 set(FFmpeg_FOUND TRUE)
 set(FFmpeg_INCLUDE_DIRS "")
 set(FFmpeg_LIBRARIES "")
+set(FFmpeg_LIBRARY_DIRS "")
 
 # Map component names to pkg-config module names
 set(_FFmpeg_PKG_AVCODEC    libavcodec)
@@ -60,10 +63,12 @@ foreach(_component ${_FFmpeg_ALL_COMPONENTS})
     set(FFmpeg_${_component}_FOUND TRUE)
     set(FFmpeg_${_component}_INCLUDE_DIRS ${_FF_${_component}_INCLUDE_DIRS})
     set(FFmpeg_${_component}_LIBRARIES ${_FF_${_component}_LIBRARIES})
+    set(FFmpeg_${_component}_LIBRARY_DIRS ${_FF_${_component}_LIBRARY_DIRS})
     set(FFmpeg_${_component}_VERSION ${_FF_${_component}_VERSION})
 
     list(APPEND FFmpeg_INCLUDE_DIRS ${_FF_${_component}_INCLUDE_DIRS})
     list(APPEND FFmpeg_LIBRARIES ${_FF_${_component}_LIBRARIES})
+    list(APPEND FFmpeg_LIBRARY_DIRS ${_FF_${_component}_LIBRARY_DIRS})
   else()
     # Fallback: try find_path + find_library
     string(TOLOWER ${_component} _comp_lower)
@@ -75,11 +80,14 @@ foreach(_component ${_FFmpeg_ALL_COMPONENTS})
       NAMES ${_comp_lower}
     )
     if (_FF_${_component}_INCDIR AND _FF_${_component}_LIB)
+      get_filename_component(_FF_${_component}_LIBDIR ${_FF_${_component}_LIB} DIRECTORY)
       set(FFmpeg_${_component}_FOUND TRUE)
       set(FFmpeg_${_component}_INCLUDE_DIRS ${_FF_${_component}_INCDIR})
       set(FFmpeg_${_component}_LIBRARIES ${_FF_${_component}_LIB})
+      set(FFmpeg_${_component}_LIBRARY_DIRS ${_FF_${_component}_LIBDIR})
       list(APPEND FFmpeg_INCLUDE_DIRS ${_FF_${_component}_INCDIR})
       list(APPEND FFmpeg_LIBRARIES ${_FF_${_component}_LIB})
+      list(APPEND FFmpeg_LIBRARY_DIRS ${_FF_${_component}_LIBDIR})
     else()
       set(FFmpeg_${_component}_FOUND FALSE)
       # Only fail overall find for required (non-optional) components
@@ -97,6 +105,9 @@ endif()
 if (FFmpeg_LIBRARIES)
   list(REMOVE_DUPLICATES FFmpeg_LIBRARIES)
 endif()
+if (FFmpeg_LIBRARY_DIRS)
+  list(REMOVE_DUPLICATES FFmpeg_LIBRARY_DIRS)
+endif()
 
 include(FindPackageHandleStandardArgs)
 find_package_handle_standard_args(FFmpeg
@@ -109,9 +120,11 @@ find_package_handle_standard_args(FFmpeg
 set(FFMPEG_FOUND ${FFmpeg_FOUND})
 set(FFMPEG_INCLUDE_DIRS ${FFmpeg_INCLUDE_DIRS})
 set(FFMPEG_LIBRARIES ${FFmpeg_LIBRARIES})
+set(FFMPEG_LIBRARY_DIRS ${FFmpeg_LIBRARY_DIRS})
 
 mark_as_advanced(
   FFmpeg_INCLUDE_DIRS
   FFmpeg_LIBRARIES
+  FFmpeg_LIBRARY_DIRS
   FFmpeg_FOUND
 )
diff --git a/src/av/CMakeLists.txt b/src/av/CMakeLists.txt
index 7ac36544..5c1e4860 100644
--- a/src/av/CMakeLists.txt
+++ b/src/av/CMakeLists.txt
@@ -5,6 +5,9 @@ icy_add_module(av
 
 # FFmpeg is optional for this module
 if(HAVE_FFMPEG AND TARGET av)
+  if(FFMPEG_LIBRARY_DIRS)
+    target_link_directories(av PUBLIC ${FFMPEG_LIBRARY_DIRS})
+  endif()
   target_link_libraries(av PUBLIC ${FFMPEG_LIBRARIES})
   target_include_directories(av PUBLIC ${FFMPEG_INCLUDE_DIRS})
 endif()
