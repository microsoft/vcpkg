{
  "name": "f3d",
  "version": "3.5.0",
  "description": "A fast and minimalist 3D viewer",
  "homepage": "https://f3d.app",
  "license": "BSD-3-Clause",
  "supports": "!(windows & (arm | uwp))",
  "dependencies": [
    "imgui",
    "nlohmann-json",
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    },
    {
      "name": "vtk",
      "default-features": false,
      "features": [
        "netcdf",
        "opengl",
        "seacas"
      ]
    }
  ],
  "features": {
    "alembic": {
      "description": "alembic plugin",
      "dependencies": [
        "alembic"
      ]
    },
    "application": {
      "description": "Build the application",
      "dependencies": [
        "cxxopts",
        "septag-dmon",
        "tinyfiledialogs"
      ]
    },
    "assimp": {
      "description": "assimp plugin",
      "dependencies": [
        "assimp"
      ]
    },
    "draco": {
      "description": "draco plugin",
      "dependencies": [
        "draco"
      ]
    },
    "exr": {
      "description": "OpenEXR images support",
      "dependencies": [
        "openexr"
      ]
    }
  }
}
