include(CMakeFindDependencyMacro)

find_dependency(fmt CONFIG)

if(NOT TARGET unofficial::kineto::headers)
    add_library(unofficial::kineto::headers INTERFACE IMPORTED)
    target_include_directories(unofficial::kineto::headers
        INTERFACE "${CMAKE_CURRENT_LIST_DIR}/../../include")
    target_link_libraries(unofficial::kineto::headers
        INTERFACE fmt::fmt-header-only)
endif()
