{
  "name": "polkit-qt-1",
  "version": "0.201.1",
  "description": "Qt6 wrapper around polkit-1",
  "homepage": "https://invent.kde.org/libraries/polkit-qt-1",
  "license": "LGPL-2.0-or-later",
  "supports": "linux",
  "dependencies": [
    "glib",
    "polkit",
    {
      "name": "qtbase",
      "default-features": false,
