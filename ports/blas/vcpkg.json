{
  "$comment": "Keep the platform expressions in sync with the wrappers installed by the portfiles!",
  "name": "blas",
  "version-date": "2023-04-14",
  "port-version": 4,
  "description": "Metapackage for packages which provide BLAS",
  "license": null,
  "dependencies": [
    {
      "name": "vcpkg-cmake",
      "host": true
    }
  ],
  "default-features": [
    "default-blas"
  ],
  "features": {
    "default-blas": {
      "description": "Use the default blas implementation.",
      "dependencies": [
        "openblas"
      ]
    },
    "force-reference-blas": {
      "description": "Force the use of blas from lapack.",
      "supports": "windows & static & !mingw",
      "dependencies": [
        {
          "name": "lapack-reference",
          "features": [
            "cblas"
          ]
        }
      ]
    }
  }
}
