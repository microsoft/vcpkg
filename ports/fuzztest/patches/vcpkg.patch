+install(DIRECTORY grammar_codegen
+        DESTINATION "${CMAKE_INSTALL_INCLUDEDIR}"
+        FILES_MATCHING
+        PATTERN "*.h"
+        PATTERN "*_test.cc" EXCLUDE
+)
+
+set(FUZZTEST_PUBLIC_TARGETS
+
+  fuzztest_bazel
+  fuzztest_blob_file
+  fuzztest_crashing_input_filename
