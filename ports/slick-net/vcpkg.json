{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "slick-net",
  "version": "3.0.0",
  "description": "A modern C++20 networking library providing HTTP/HTTPS client, WebSocket/WebSocket Secure client, and HTTP streaming support built on Boost.Beast and Boost.Asio",
  "homepage": "https://github.com/SlickQuant/slick-net",
  "license": "MIT",
  "supports": "!uwp",
  "dependencies": [
    {
      "name": "boost-asio",
      "version>=": "1.84.0#1"
    },
    {
      "name": "boost-beast",
      "version>=": "1.84.0#1"
    },
    {
      "name": "boost-context",
      "version>=": "1.84.0#1"
    },
    {
      "name": "boost-system",
      "version>=": "1.84.0#1"
    },
    {
      "name": "openssl",
      "version>=": "3.0.2"
    },
    {
      "name": "slick-dynamic-buffer",
      "version>=": "1.0.1"
    },
    {
      "name": "slick-queue",
      "version>=": "1.5.0"
    },
    {
      "name": "slick-stream-buffer",
      "version>=": "1.0.5"
    },
    {
      "name": "slick-stream-buffer-multiplexer",
      "version>=": "1.0.1"
    },
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    }
  ]
}
