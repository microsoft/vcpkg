{
  "name": "libxkbfile",
  "version": "1.2.0",
  "description": "XKB file handling routines",
  "homepage": "https://gitlab.freedesktop.org/xorg/lib/libxkbfile",
  "license": null,
  "supports": "!windows | mingw",
  "dependencies": [
    "libx11",
    {
      "name": "vcpkg-tool-meson",
      "host": true
    },
    "xproto"
  ],
  "features": {
    "force-build": {
      "description": "Forces the library to be built always, regardless of X_VCPKG_FORCE_VCPKG_X_LIBRARIES.",
      "supports": "linux"
    }
  }
}
