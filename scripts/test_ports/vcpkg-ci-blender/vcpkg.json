{
  "name": "vcpkg-ci-blender",
  "version": "4.5.8",
  "description": "3D creation suite",
  "homepage": "https://www.blender.org/",
  "license": "GPL-2.0-or-later",
  "supports": "(x64 & (windows | linux)) | osx",
  "dependencies": [
    "bzip2",
    "freetype",
    "libepoxy",
    "libjpeg-turbo",
    "liblzma",
    "libpng",
    {
      "name": "openimageio",
      "features": [
        "opencolorio"
      ]
    },
    "pthreads",
    "tiff",
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    },
    "zlib",
    "zstd"
  ]
}
