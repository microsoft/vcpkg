{
  "name": "vcpkg-ci-alibabacloud-oss-cpp-sdk-v2",
  "version-string": "ci",
  "description": "Builds a link-compatibility check for the Alibaba OSS SDK ports and separately installed sandboxed third-party libraries",
  "homepage": "https://github.com/microsoft/vcpkg",
  "license": "MIT",
  "supports": "!emscripten",
  "dependencies": [
    {
      "name": "alibabacloud-oss-cpp-sdk-v2",
      "features": [
        "winhttp"
      ],
      "platform": "windows"
    },
    {
      "name": "alibabacloud-oss-cpp-sdk-v2",
      "features": [
        "curl"
      ],
      "platform": "!windows"
    },
    {
      "name": "aliyun-oss-cpp-sdk",
      "platform": "linux | osx | android"
    },
    "boost-beast",
    "tinyxml2",
    {
      "name": "vcpkg-cmake",
      "host": true
    }
  ]
}
